OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/anthropic/claude-sonnet-4
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:8501
OPENROUTER_APP_NAME=CodeLens
# If you see 402 "more credits, or fewer max_tokens", lower this (e.g. 1500) or add credits.
OPENROUTER_MAX_TOKENS=4096
PINECONE_API_KEY=
VOYAGE_API_KEY=
GITHUB_TOKEN=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
APP_URL=http://localhost:8501
GITNEXUS_USE_EMBEDDINGS=1
GITNEXUS_CLONE_DEPTH=1
GITNEXUS_FILE_LIMIT=2000
# CrewAI → OpenRouter: keep prompts under ~8MB (optional caps)
CREW_MAX_ANALYSIS_JSON_BYTES=5500000
CREW_MAX_FILES=48
CREW_MAX_FILE_CONTENT_CHARS=9500
