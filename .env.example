OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/google/gemma-4-26b-a4b-it
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:8501
OPENROUTER_APP_NAME=CodeLens
# Default 2048 saves cost; raise to 4096 if agent JSON responses get cut off.
# If you see 402, lower further (e.g. 1500) or add credits.
OPENROUTER_MAX_TOKENS=2048
PINECONE_API_KEY=
VOYAGE_API_KEY=
GITHUB_TOKEN=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
APP_URL=http://localhost:8501
GITNEXUS_USE_EMBEDDINGS=1
GITNEXUS_CLONE_DEPTH=1
GITNEXUS_FILE_LIMIT=2000
# CrewAI: efficient = 2 LLM calls (default). full = 4–5 specialist agents (richer, costly).
CREWAI_MODE=efficient
# Optional: minimum seconds between Analyze runs (0 = off)
CODELENS_ANALYSIS_COOLDOWN_SECONDS=0
# CrewAI → OpenRouter: keep prompts under ~8MB (optional caps; efficient mode uses tighter defaults if unset)
CREW_MAX_ANALYSIS_JSON_BYTES=5500000
CREW_MAX_FILES=48
CREW_MAX_FILE_CONTENT_CHARS=9500
